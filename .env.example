# ============================================
# FIREBASE CONFIGURATION
# ============================================
# หา Config เหล่านี้ที่: Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=my-etf-portfolio.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=my-etf-portfolio
VITE_FIREBASE_STORAGE_BUCKET=my-etf-portfolio.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ============================================
# STOCK DATA API KEYS
# ============================================

# Financial Modeling Prep (FMP)
# สมัครที่: https://site.financialmodelingprep.com/developer/docs
# Free tier: 250 requests/day
VITE_FMP0N8_API_KEY=your_fmp_api_key_here

# Finnhub
# สมัครที่: https://finnhub.io/
# Free tier: 60 API calls/minute
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here

# Twelve Data
# สมัครที่: https://twelvedata.com/
# Free tier: 800 API credits/day
VITE_TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# EODHD (End of Day Historical Data)
# สมัครที่: https://eodhd.com/
# Free tier: 20 API requests/day
VITE_EODHD_API_KEY=your_eodhd_api_key_here

# ============================================
# NOTES
# ============================================
# 1. คัดลอกไฟล์นี้และเปลี่ยนชื่อเป็น .env
# 2. แทนที่ค่า your_*_here ด้วย API keys จริง
# 3. ไฟล์ .env จะถูก .gitignore (ไม่ถูก commit ขึ้น GitHub)
# 4. ใน Vercel: ตั้งค่า Environment Variables ในหน้า Settings
