# ===================================================
# FIREBASE CONFIGURATION
# ===================================================
# ใน Config เหนือนี้: Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# GitHub API sync
VITE_GITHUB_OWNER=navykao
VITE_GITHUB_REPO=my-etf-portfolio
VITE_GITHUB_TOKEN=github_pat_xxxx

# ===================================================
# STOCK DATA API KEYS
# ===================================================

# Financial Modeling Prep (FMP)
# คู่มือ: https://site.financialmodelingprep.com/developer/docs
# Free tier: 250 requests/day
VITE_FMP0N8_API_KEY=your_fmp_api_key_here

# Finnhub
# คู่มือ: https://finnhub.io/
# Free tier: 60 API calls/minute
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here

# Twelve Data
# คู่มือ: https://twelvedata.com/
# Free tier: 800 API credits/day
VITE_TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# EODHD
# คู่มือ: https://eodhistoricaldata.com/
# Free tier: 20 API calls/day
VITE_EODHD_API_KEY=your_eodhd_api_key_here
